# Gmail HTTPS API (required on Railway — SMTP ports are blocked)
MAIL_PROVIDER=gmail
MAIL_USER=info@equvinoxis.com
MAIL_FROM=Equvinoxis <info@equvinoxis.com>
MAIL_TO=info@equvinoxis.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Local dev only (SMTP works locally, not on Railway)
# MAIL_PASS=your-gmail-app-password

# Server
PORT=3001
NODE_ENV=development
