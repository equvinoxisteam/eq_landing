# Railway blocks SMTP ports — use HTTPS providers on production
MAIL_PROVIDER=gmail
MAIL_USER=info@equvinoxis.com
MAIL_FROM=Equvinoxis <info@equvinoxis.com>
MAIL_TO=info@equvinoxis.com

# Option A (recommended on Railway): free key from https://web3forms.com
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Option B: Gmail HTTPS API (OAuth Playground refresh token)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Option C: SMTP — local dev only (blocked on Railway)
# MAIL_PASS=your-gmail-app-password

# Server
PORT=3001
NODE_ENV=development
