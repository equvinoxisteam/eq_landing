# Mail — Gmail HTTPS API (recommended for Railway)
MAIL_PROVIDER=gmail
MAIL_USER=info@equvinoxis.com
MAIL_FROM=Equvinoxis <info@equvinoxis.com>
MAIL_TO=info@equvinoxis.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Optional SMTP fallback (set MAIL_ALLOW_SMTP_FALLBACK=true to enable)
# MAIL_PASS=your-gmail-app-password
# MAIL_ALLOW_SMTP_FALLBACK=true

# Server
PORT=3001
NODE_ENV=development
