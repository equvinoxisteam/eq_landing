# Mail provider: auto | gmail | smtp | formsubmit | log
# gmail / smtp = Gmail SMTP when MAIL_USER + MAIL_PASS are set
MAIL_PROVIDER=gmail
MAIL_USER=info@equvinoxis.com
MAIL_PASS=your-gmail-app-password
MAIL_FROM=Equvinoxis <info@equvinoxis.com>
MAIL_TO=info@equvinoxis.com

# Optional Gmail OAuth (only if GMAIL_REFRESH_TOKEN is configured)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# SMTP overrides (defaults: smtp.gmail.com:587)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Server
PORT=3001
NODE_ENV=development
