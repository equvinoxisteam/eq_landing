# Gmail HTTPS API (required on Railway — SMTP ports are blocked)
MAIL_PROVIDER=gmail
MAIL_USER=info@equvinoxis.com
MAIL_FROM=Equvinoxis <info@equvinoxis.com>
MAIL_TO=info@equvinoxis.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Easiest on Railway — sign up at https://web3forms.com
WEB3FORMS_ACCESS_KEY=your-access-key
# Aliases also supported: WEB3FORMS_KEY, WEB3FORMS_API_KEY

# Server
PORT=3001
NODE_ENV=development
